{
  "name": "@auto-deck/ui",
  "version": "0.1.0",
  "description": "Shared UI components, hooks, and utilities built on shadcn and Base UI",
  "private": true,
  "type": "module",
  "license": "MIT",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/geist": "5.2.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "react": "catalog:",
    "react-resizable-panels": "catalog:",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@auto-deck/tsconfig": "workspace:*",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
