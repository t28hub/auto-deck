{
  "name": "@auto-deck/root",
  "private": true,
  "version": "0.1.0",
  "description": "",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t28hub/auto-deck.git"
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "biome format --write",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "turbo test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "lefthook": "2.1.9",
    "turbo": "2.10.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.9.0"
}
